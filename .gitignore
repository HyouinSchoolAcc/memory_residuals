__pycache__/
*.pyc
*.egg-info/
dist/
build/
.eggs/
*.safetensors
data_pipeline/
tea_debug.log
wandb/

# Training runs (heavy checkpoints). One folder per cell; each
# promoted run is referenced by name in runs.md.
runs/
output
# ^ `output` is a backwards-compat symlink to `runs/` kept because
#   many train scripts have the literal `output/...` path baked into
#   their launch command.

# Training & sync logs (one .log per cell, paired with runs/<cell>/).
logs/

# Large pre-tokenised corpora. Built by tools/build_*; cited in
# runs.md by filename. Too big for git; regenerable from source.
paper_artifacts/chains/*.pt
paper_artifacts/locomo_chains/
paper_artifacts/msc_chains_test/

# Compiled paper PDFs are committed for reviewer access; LaTeX
# byproducts below are not.

# Cloud watchdog state directories.
tools/cloud_watchdog/queue/
tools/cloud_watchdog/running/
tools/cloud_watchdog/done/
tools/cloud_watchdog/failed/
tools/cloud_watchdog/.ntfy_topic

# archive/ holds the historical paper trail (scripts, docs, eval JSONs,
# figures, the COMPREHENSIVE.md ledger). It's small (~1 MB) and
# committed so the v1-v10 narrative is reproducible.

# LaTeX build artifacts from compiling memory_residuals.tex /
# atn_residuals.tex / results/exp1_*/manuscript.tex /
# results/exp2_*/draft.tex. Only the .pdf is committed.
*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz
*.bbl
*.blg
*.nav
*.snm
*.vrb

# Python bytecode cache (covers nested __pycache__ trees as well).
**/__pycache__/
*.pyo

# Editor / OS noise.
.DS_Store
.vscode/
.idea/
*.swp
*~

# Local secrets (OpenRouter / cloud audit creds). Never commit.
env.local.bat
env.local.sh
.env
.env.local
