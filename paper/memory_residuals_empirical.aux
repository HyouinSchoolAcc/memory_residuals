\citation{liu2025memres}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Per-callback NLL probe on PG-19 test held-out pairs. The ``callback'' bucket consists of tokens that are part of a capitalised multi-character word also present in the history; ``filler'' is everything else. A ratio above $1.5\times $ is the success criterion. (Filled in by the \texttt  {post\_train\_pipeline.sh} wrapper after both chain-v3 runs finish.)}}{8}{table.4}\protected@file@percent }
\newlabel{tab:callback}{{4}{8}{Per-callback NLL probe on PG-19 test held-out pairs. The ``callback'' bucket consists of tokens that are part of a capitalised multi-character word also present in the history; ``filler'' is everything else. A ratio above $1.5\times $ is the success criterion. (Filled in by the \texttt {post\_train\_pipeline.sh} wrapper after both chain-v3 runs finish.)}{table.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Per-sublayer learned routing weight on the memory source. \textsc  {simple\_gate} concentrates routing mass at the deepest sublayers (gates initialised at zero, allowed to drift away from zero); \textsc  {attention\_parity} (soft) maintains a non-trivial mass at every depth via the depth-wise pool.}}{8}{figure.3}\protected@file@percent }
\newlabel{fig:gate}{{3}{8}{Per-sublayer learned routing weight on the memory source. \textsc {simple\_gate} concentrates routing mass at the deepest sublayers (gates initialised at zero, allowed to drift away from zero); \textsc {attention\_parity} (soft) maintains a non-trivial mass at every depth via the depth-wise pool}{figure.3}{}}
